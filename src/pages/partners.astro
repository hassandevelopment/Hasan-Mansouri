---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const partners = [
  {
    name: 'M & I Construction W.L.L.',
    badge: 'Civil & Building Contractor',
    established: '1976',
    description: 'A reputable building and civil engineering contractor established in 1976 in Bahrain. With offices in Mina Salman and Askar, M & I Construction brings professional management, qualified engineers, and skilled workers to every project — delivering quality outcomes on schedule.',
    details: [
      { label: 'Established', value: '1976' },
      { label: 'Locations',   value: 'Mina Salman & Askar, Bahrain' },
      { label: 'Speciality',  value: 'Civil Engineering & Construction' },
    ],
  },
  {
    name: 'Spacemaker',
    badge: 'Modular & Timber Frame Buildings',
    description: 'A division of M & I Construction WLL, Spacemaker manufactures custom-built timber frame houses, villas, schools, offices, and work camps. Factory-controlled quality and standardised methods mean faster builds with no heavy foundations required. Also produces joinery items including doors, windows, wardrobes, and kitchen components.',
    details: [
      { label: 'Division of', value: 'M & I Construction WLL' },
      { label: 'Products',    value: 'Villas, Offices, Schools, Camps' },
      { label: 'Method',      value: 'Factory-built, no heavy foundations' },
    ],
  },
];
---

<Base
  title="Partners"
  description="Associated companies of the Hasan Mansouri Group — M & I Construction WLL and Spacemaker Portable Buildings."
>
  <Nav slot="nav" />

  <div style="background:#4A0A11;padding:4rem 0 3rem;">
    <div class="container">
      <span class="section-label">Associated Companies</span>
      <h1 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2.5rem,5vw,3.5rem);font-weight:700;color:#FAF6F0;margin-bottom:0.75rem;line-height:1.1;">Partners</h1>
      <p style="font-family:'Inter Variable',system-ui,sans-serif;font-size:1rem;color:rgba(250,246,240,0.6);max-width:520px;line-height:1.7;">Long-standing partnerships that extend the Group's capabilities in construction and modular building.</p>
    </div>
  </div>

  <section style="background:#FAF6F0;padding:5rem 0;">
    <div class="container">
      <div style="display:flex;flex-direction:column;gap:2rem;max-width:900px;">

        {partners.map((p, i) => (
          <div class="reveal" style={`
            background:#FFFFFF;
            border-radius:1rem;
            border:1px solid rgba(110,16,25,0.1);
            padding:2.5rem;
            transition-delay:${i * 80}ms;
          `}>
            <div style="
              display:inline-block;
              background:rgba(110,16,25,0.08);
              color:#6E1019;
              font-family:'Inter Variable',system-ui,sans-serif;
              font-size:0.625rem;font-weight:700;
              letter-spacing:0.14em;text-transform:uppercase;
              padding:0.375rem 0.75rem;border-radius:2px;
              margin-bottom:1rem;
            ">{p.badge}</div>

            <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:1.5rem;font-weight:700;color:#2D1F1F;margin-bottom:0.875rem;">{p.name}</h2>
            <p style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9375rem;color:#524444;line-height:1.875;margin-bottom:1.5rem;">{p.description}</p>

            <div style="
              display:flex;gap:2rem;flex-wrap:wrap;
              padding-top:1.25rem;
              border-top:1px solid rgba(110,16,25,0.08);
            ">
              {p.details.map(({ label, value }) => (
                <div>
                  <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.625rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#B8956A;margin-bottom:0.25rem;">{label}</div>
                  <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.875rem;font-weight:600;color:#2D1F1F;">{value}</div>
                </div>
              ))}
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>
