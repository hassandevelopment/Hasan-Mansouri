---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const contacts = [
  {
    name: 'Head Office',
    address: 'Bldg 302, Road 4306, Block 343\nMina Salman Industrial Area, Entrance 2\nKingdom of Bahrain',
    po: 'P.O. Box 5185, Manama',
    phone: '(+973) 1772 8144',
    fax: '(+973) 1772 9976',
    email: 'office@hasanmansouri.com',
  },
  {
    name: 'Mansouri Mansions Hotel',
    address: 'Adliya, Manama',
    po: 'P.O. Box 5587, Manama',
    phone: '(+973) 1771 6999',
    email: 'sizzlers@batelco.com.bh',
  },
  {
    name: 'The Country Club',
    address: '15 minutes from Manama',
    phone: '(+973) 1759 3593',
    fax: '(+973) 1759 3751',
    email: 'brenigan@batelco.com.bh',
  },
];
---

<Base
  title="Contact"
  description="Contact the Hasan Mansouri Group — Head Office in Mina Salman, Mansouri Mansions Hotel, and The Country Club."
>
  <Nav slot="nav" />

  <div style="background:#4A0A11;padding:4rem 0 3rem;">
    <div class="container">
      <span class="section-label">Get in Touch</span>
      <h1 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2.5rem,5vw,3.5rem);font-weight:700;color:#FAF6F0;margin-bottom:0.75rem;line-height:1.1;">Contact the Group</h1>
      <p style="font-family:'Inter Variable',system-ui,sans-serif;font-size:1rem;color:rgba(250,246,240,0.6);max-width:520px;line-height:1.7;">Reach us at our head office or directly at one of our divisions.</p>
    </div>
  </div>

  <section style="background:#FAF6F0;padding:5rem 0;">
    <div class="container">
      <div class="contact-main-grid">

        <!-- Contact info -->
        <div>
          <span class="section-label reveal">Our Locations</span>

          <div style="display:flex;flex-direction:column;gap:1.25rem;">
            {contacts.map((c, i) => (
              <div class="reveal" style={`
                background:#FFFFFF;border-radius:1rem;
                border:1px solid rgba(110,16,25,0.1);
                padding:1.75rem;
                transition-delay:${i * 80}ms;
              `}>
                <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:1.0625rem;font-weight:700;color:#2D1F1F;margin-bottom:1.125rem;">{c.name}</h2>
                <div style="display:flex;flex-direction:column;gap:0.625rem;">
                  {c.address && (
                    <div style="display:flex;align-items:flex-start;gap:0.625rem;">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px;" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                      <span style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.8125rem;color:#524444;line-height:1.6;white-space:pre-line;">{c.address}</span>
                    </div>
                  )}
                  {c.po && (
                    <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.8125rem;color:#524444;padding-left:1.375rem;">{c.po}</div>
                  )}
                  {c.phone && (
                    <div style="display:flex;align-items:center;gap:0.625rem;">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.12 6.12l.95-.88a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                      <a href={`tel:${c.phone.replace(/[^+\d]/g, '')}`} style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.8125rem;color:#6E1019;text-decoration:none;font-weight:500;">{c.phone}</a>
                    </div>
                  )}
                  {c.fax && (
                    <div style="display:flex;align-items:center;gap:0.625rem;">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 17H2a3 3 0 0 1-3-3V9a3 3 0 0 1 3-3h20a3 3 0 0 1 3 3v5a3 3 0 0 1-3 3z"/><polyline points="22 3 2 3 2 7"/><line x1="6" y1="12" x2="10" y2="12"/></svg>
                      <span style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.8125rem;color:#524444;">Fax: {c.fax}</span>
                    </div>
                  )}
                  {c.email && (
                    <div style="display:flex;align-items:center;gap:0.625rem;">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B8956A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                      <a href={`mailto:${c.email}`} style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.8125rem;color:#6E1019;text-decoration:none;font-weight:500;">{c.email}</a>
                    </div>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Contact form -->
        <div class="reveal reveal-delay-1">
          <div style="background:#FFFFFF;border-radius:1rem;border:1px solid rgba(110,16,25,0.1);padding:2.5rem;">
            <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:1.375rem;font-weight:700;color:#2D1F1F;margin-bottom:0.5rem;">Send a Message</h2>
            <p style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.8125rem;color:#524444;margin-bottom:2rem;line-height:1.65;">We'll respond within two business days. For urgent matters, call (+973) 1772 8144 directly.</p>

            <form
              action="https://formspree.io/f/YOUR_FORM_ID"
              method="POST"
              style="display:flex;flex-direction:column;gap:1.125rem;"
            >
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;" class="form-row">
                <div>
                  <label for="first_name" style="display:block;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#2D1F1F;margin-bottom:0.5rem;">First Name <span aria-label="required" style="color:#6E1019;">*</span></label>
                  <input
                    type="text"
                    id="first_name"
                    name="first_name"
                    required
                    autocomplete="given-name"
                    style="width:100%;padding:0.6875rem 0.875rem;border:1px solid rgba(110,16,25,0.18);border-radius:4px;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9rem;color:#2D1F1F;background:#FFFFFF;outline:none;transition:border-color 150ms;"
                  />
                </div>
                <div>
                  <label for="last_name" style="display:block;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#2D1F1F;margin-bottom:0.5rem;">Last Name <span aria-label="required" style="color:#6E1019;">*</span></label>
                  <input
                    type="text"
                    id="last_name"
                    name="last_name"
                    required
                    autocomplete="family-name"
                    style="width:100%;padding:0.6875rem 0.875rem;border:1px solid rgba(110,16,25,0.18);border-radius:4px;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9rem;color:#2D1F1F;background:#FFFFFF;outline:none;transition:border-color 150ms;"
                  />
                </div>
              </div>

              <div>
                <label for="company" style="display:block;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#2D1F1F;margin-bottom:0.5rem;">Company</label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  autocomplete="organization"
                  style="width:100%;padding:0.6875rem 0.875rem;border:1px solid rgba(110,16,25,0.18);border-radius:4px;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9rem;color:#2D1F1F;background:#FFFFFF;outline:none;transition:border-color 150ms;"
                />
              </div>

              <div>
                <label for="email" style="display:block;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#2D1F1F;margin-bottom:0.5rem;">Email <span aria-label="required" style="color:#6E1019;">*</span></label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  autocomplete="email"
                  style="width:100%;padding:0.6875rem 0.875rem;border:1px solid rgba(110,16,25,0.18);border-radius:4px;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9rem;color:#2D1F1F;background:#FFFFFF;outline:none;transition:border-color 150ms;"
                />
              </div>

              <div>
                <label for="phone" style="display:block;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#2D1F1F;margin-bottom:0.5rem;">Phone</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  autocomplete="tel"
                  style="width:100%;padding:0.6875rem 0.875rem;border:1px solid rgba(110,16,25,0.18);border-radius:4px;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9rem;color:#2D1F1F;background:#FFFFFF;outline:none;transition:border-color 150ms;"
                />
              </div>

              <div>
                <label for="subject" style="display:block;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#2D1F1F;margin-bottom:0.5rem;">Enquiry relates to <span aria-label="required" style="color:#6E1019;">*</span></label>
                <select
                  id="subject"
                  name="subject"
                  required
                  style="width:100%;padding:0.6875rem 0.875rem;border:1px solid rgba(110,16,25,0.18);border-radius:4px;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9rem;color:#2D1F1F;background:#FFFFFF;outline:none;transition:border-color 150ms;appearance:auto;"
                >
                  <option value="">Select a division</option>
                  <option>General Enquiry</option>
                  <option>Hasan Mansouri Engineering</option>
                  <option>Hasan Mansouri Transport</option>
                  <option>Hasan Mansouri Properties</option>
                  <option>Mansouri Mansions Hotel</option>
                  <option>The Country Club</option>
                  <option>Tiffany's Restaurant</option>
                  <option>Maguire's Irish Pub</option>
                  <option>Hasan Mansouri Sports</option>
                  <option>Hasan Mansouri Laundry</option>
                  <option>M & I Construction / Spacemaker</option>
                  <option>Careers</option>
                </select>
              </div>

              <div>
                <label for="message" style="display:block;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#2D1F1F;margin-bottom:0.5rem;">Message <span aria-label="required" style="color:#6E1019;">*</span></label>
                <textarea
                  id="message"
                  name="message"
                  required
                  rows="5"
                  style="width:100%;padding:0.6875rem 0.875rem;border:1px solid rgba(110,16,25,0.18);border-radius:4px;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9rem;color:#2D1F1F;background:#FFFFFF;outline:none;transition:border-color 150ms;resize:vertical;min-height:120px;"
                ></textarea>
              </div>

              <button type="submit" class="btn-primary" style="justify-content:center;">
                Send Message
              </button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .contact-main-grid {
    display: grid;
    grid-template-columns: 1fr 1.25fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .contact-main-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr !important;
    }
  }

  input:focus, textarea:focus, select:focus {
    border-color: #B8956A !important;
    box-shadow: 0 0 0 3px rgba(184,149,106,0.12);
  }
</style>
