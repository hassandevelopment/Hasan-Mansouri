---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const subsidiaries = (await getCollection('subsidiaries')).sort(
  (a, b) => a.data.order - b.data.order
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sectors = [
  { key: 'construction', label: 'Construction & Engineering' },
  { key: 'property',     label: 'Property' },
  { key: 'hospitality',  label: 'Hospitality' },
  { key: 'services',     label: 'Services' },
];

const sectorIcons: Record<string, string> = {
  construction: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 20h20"/><path d="M5 20V9l7-7 7 7v11"/><path d="M9 20v-5h6v5"/></svg>`,
  property:     `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  hospitality:  `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>`,
  services:     `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
};

const stats = [
  { num: '65+',    label: 'Years in Business' },
  { num: '9',      label: 'Business Divisions' },
  { num: '40,000', label: 'sq.m Steel Facility' },
  { num: '1979',   label: 'Hotel Established' },
];
---

<Base
  title="Hasan Mansouri Group"
  description="A Bahrain-based holding company founded in 1960. Engineering, hospitality, real estate, transport, and services across the Kingdom."
>
  <Nav slot="nav" />

  <!-- ── HERO ── -->
  <section
    aria-label="Welcome"
    style="
      min-height: calc(100dvh - 64px);
      background: #3A0810;
      position: relative;
      display: flex;
      align-items: center;
      overflow: hidden;
    "
  >
    <!-- Geometric texture -->
    <div
      aria-hidden="true"
      style="
        position: absolute;
        inset: 0;
        background-image: url(\"data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23B8956A' stroke-opacity='0.055' stroke-width='0.5'%3E%3Cpath d='M0 20h40M20 0v40M0 0l40 40M40 0L0 40'/%3E%3C/g%3E%3C/svg%3E\");
      "
    ></div>

    <!-- Right photo zone — Mansouri Mansions Hotel exterior -->
    <div
      aria-hidden="true"
      style="
        position: absolute;
        right: 0; top: 0; bottom: 0;
        width: 45%;
        background: #2A0608;
        overflow: hidden;
      "
    >
      <img
        src={`${base}/images/subsidiaries/mansouri-mansions/entrance.jpg`}
        alt=""
        loading="eager"
        decoding="async"
        style="
          position: absolute;
          inset: 0;
          width: 100%;
          height: 100%;
          object-fit: cover;
          object-position: center;
          opacity: 0.7;
        "
      />
      <div style="position:absolute;inset:0;background:linear-gradient(to right,#3A0810 0%,transparent 50%);"></div>
    </div>

    <div class="container" style="position:relative;z-index:1;padding-top:4rem;padding-bottom:4rem;">
      <div style="max-width:560px;">

        <div class="reveal" style="
          display: inline-block;
          border: 1px solid rgba(184,149,106,0.35);
          background: rgba(184,149,106,0.08);
          color: #B8956A;
          font-family: 'Inter Variable', system-ui, sans-serif;
          font-size: 0.6875rem;
          font-weight: 700;
          letter-spacing: 0.18em;
          text-transform: uppercase;
          padding: 0.375rem 0.875rem;
          border-radius: 2px;
          margin-bottom: 1.5rem;
        ">Established 1960 · Kingdom of Bahrain</div>

        <h1 class="reveal reveal-delay-1" style="
          font-family: 'Fraunces Variable', Georgia, serif;
          font-size: clamp(2.5rem, 6vw, 4rem);
          font-weight: 700;
          color: #FAF6F0;
          line-height: 1.1;
          margin: 0 0 1.25rem;
        ">
          Building Bahrain<br>
          <span style="color:#B8956A;">since 1960.</span>
        </h1>

        <p class="reveal reveal-delay-2" style="
          font-family: 'Inter Variable', system-ui, sans-serif;
          font-size: 1.0625rem;
          color: rgba(250,246,240,0.68);
          line-height: 1.75;
          margin: 0 0 2.25rem;
          max-width: 460px;
        ">
          The Hasan Mansouri Group is one of Bahrain's most established private conglomerates — spanning engineering, hospitality, real estate, transport, and services.
        </p>

        <div class="reveal reveal-delay-3" style="display:flex;gap:0.875rem;flex-wrap:wrap;">
          <a href={`${base}/subsidiaries`} class="btn-primary">Our Businesses</a>
          <a href={`${base}/about`} style="
            display:inline-flex;align-items:center;
            background:transparent;
            color:rgba(250,246,240,0.8);
            padding:0.75rem 1.75rem;
            border:1.5px solid rgba(250,246,240,0.25);
            border-radius:3px;
            font-family:'Inter Variable',system-ui,sans-serif;
            font-size:0.875rem;font-weight:600;
            text-decoration:none;
            transition:border-color 150ms,color 150ms;
          ">Our Story</a>
        </div>

        <!-- Stats -->
        <div class="reveal reveal-delay-4" style="
          display:flex;gap:2.5rem;
          margin-top:3.5rem;
          padding-top:2rem;
          border-top:1px solid rgba(250,246,240,0.1);
          flex-wrap:wrap;
        ">
          {stats.map(({ num, label }) => (
            <div>
              <div style="
                font-family:'Fraunces Variable',Georgia,serif;
                font-size:1.875rem;font-weight:700;
                color:#B8956A;line-height:1;
              ">{num}</div>
              <div style="
                font-family:'Inter Variable',system-ui,sans-serif;
                font-size:0.6875rem;font-weight:500;
                letter-spacing:0.1em;text-transform:uppercase;
                color:rgba(250,246,240,0.4);margin-top:0.375rem;
              ">{label}</div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>

  <!-- ── ABOUT STRIP ── -->
  <section style="background:#FAF6F0;padding:5rem 0;" aria-label="About the Group">
    <div class="container">
      <div class="about-strip-grid">

        <!-- Leadership card -->
        <div class="reveal" style="
          background:#4A0A11;border-radius:1rem;
          padding:2.5rem 2rem;position:relative;overflow:hidden;
        ">
          <div aria-hidden="true" style="position:absolute;top:-20px;right:-20px;width:100px;height:100px;border:1px solid rgba(184,149,106,0.12);border-radius:50%;"></div>
          <div aria-hidden="true" style="position:absolute;bottom:-40px;left:-40px;width:160px;height:160px;border:1px solid rgba(184,149,106,0.07);border-radius:50%;"></div>

          <div style="
            font-family:'Inter Variable',system-ui,sans-serif;
            font-size:0.625rem;font-weight:700;
            letter-spacing:0.18em;text-transform:uppercase;
            color:#B8956A;margin-bottom:0.5rem;
          ">Founded</div>
          <div style="
            font-family:'Fraunces Variable',Georgia,serif;
            font-size:3.5rem;font-weight:700;
            color:rgba(184,149,106,0.18);line-height:1;margin-bottom:1.5rem;
          " aria-hidden="true">1960</div>

          <div style="position:relative;">
            <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.625rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(250,246,240,0.4);margin-bottom:0.375rem;">Chairman</div>
            <div style="font-family:'Fraunces Variable',Georgia,serif;font-size:1.25rem;font-weight:700;color:#FAF6F0;margin-bottom:0.25rem;">Mr. Hasan Mansouri</div>
            <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.8125rem;color:#B8956A;">Founder &amp; Chairman</div>

            <div style="width:36px;height:1px;background:#B8956A;opacity:0.35;margin:1.25rem 0;"></div>

            <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.625rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:rgba(250,246,240,0.4);margin-bottom:0.375rem;">Managing Director</div>
            <div style="font-family:'Fraunces Variable',Georgia,serif;font-size:1.125rem;font-weight:600;color:#FAF6F0;">Mr. Karim Mansouri</div>
          </div>
        </div>

        <!-- Text -->
        <div>
          <span class="section-label reveal">Our Story</span>
          <h2 class="reveal reveal-delay-1" style="
            font-family:'Fraunces Variable',Georgia,serif;
            font-size:clamp(1.75rem,3vw,2.5rem);
            font-weight:700;color:#8B2A2A;margin-bottom:1rem;
          ">From one man's vision<br>to Bahrain's trusted Group.</h2>
          <span class="divider-gold reveal reveal-delay-1" style="margin-bottom:1.25rem;"></span>

          <p class="reveal reveal-delay-2" style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9375rem;color:#524444;line-height:1.875;margin-bottom:1rem;">
            Founded in 1960 at Mina Salman, what began as a steel fabrication enterprise grew into one of Bahrain's most diversified and respected business groups — spanning engineering, real estate, hospitality, transport, and services.
          </p>
          <p class="reveal reveal-delay-2" style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9375rem;color:#524444;line-height:1.875;margin-bottom:1.75rem;">
            The Group's values of honesty, dedication, and reliability have guided every venture over 65 years, earning the trust of government bodies, industrial clients, and private citizens across the Kingdom.
          </p>

          <div class="reveal reveal-delay-3" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.75rem;">
            {[
              { title: 'Steel Fabrication', text: 'Founded 1960 at Mina Salman' },
              { title: 'Hotel Heritage',    text: 'Mansouri Mansions since 1979' },
              { title: '40,000 sq.m',       text: "Bahrain's largest steel facility" },
              { title: '9 Divisions',       text: 'Active across key sectors' },
            ].map(({ title, text }) => (
              <div style="background:#FFFFFF;border-radius:0.5rem;padding:1rem 1.125rem;border-left:2px solid #B8956A;">
                <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.8125rem;font-weight:600;color:#2D1F1F;margin-bottom:0.25rem;">{title}</div>
                <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.75rem;color:#524444;line-height:1.5;">{text}</div>
              </div>
            ))}
          </div>

          <a href={`${base}/about`} class="btn-ghost reveal reveal-delay-3">
            Read the full story
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SUBSIDIARIES GRID ── -->
  <section id="subsidiaries" style="background:#FFFFFF;padding:5rem 0;" aria-label="Our businesses">
    <div class="container">
      <div class="reveal" style="max-width:560px;margin-bottom:3.5rem;">
        <span class="section-label">Our Businesses</span>
        <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(2rem,4vw,2.75rem);font-weight:700;color:#8B2A2A;margin-bottom:0.75rem;">Nine divisions.<br>One Group.</h2>
        <span class="divider-gold" style="margin-bottom:1rem;"></span>
        <p style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9375rem;color:#524444;line-height:1.75;">From steel fabrication to four-star hospitality — the Hasan Mansouri Group operates across the sectors that shape Bahrain's everyday life.</p>
      </div>

      {sectors.map(({ key, label }) => {
        const items = subsidiaries.filter(s => s.data.sector === key);
        if (!items.length) return null;
        return (
          <div style="margin-bottom:3rem;">
            <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1.25rem;padding-bottom:0.75rem;border-bottom:1px solid rgba(110,16,25,0.1);">
              <div style="width:30px;height:30px;background:#6E1019;border-radius:5px;display:flex;align-items:center;justify-content:center;color:#B8956A;flex-shrink:0;" set:html={sectorIcons[key]}></div>
              <h3 style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.6875rem;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#6E1019;margin:0;">{label}</h3>
            </div>

            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;">
              {items.map((sub, i) => (
                <a
                  href={`/subsidiaries/${sub.id.replace(/\.md$/, "")}`}
                  class="card reveal"
                  style={`text-decoration:none;display:flex;flex-direction:column;transition-delay:${i * 60}ms;`}
                >
                  <div style="width:38px;height:38px;background:rgba(110,16,25,0.07);border-radius:7px;display:flex;align-items:center;justify-content:center;margin-bottom:0.875rem;color:#6E1019;flex-shrink:0;" set:html={sectorIcons[sub.data.sector]}></div>
                  <h4 style="font-family:'Fraunces Variable',Georgia,serif;font-size:1.0625rem;font-weight:700;color:#2D1F1F;margin-bottom:0.5rem;line-height:1.25;">{sub.data.name}</h4>
                  <p style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.8125rem;color:#524444;line-height:1.7;flex:1;">{sub.data.tagline}</p>
                  <div style="display:flex;align-items:center;gap:0.375rem;margin-top:0.875rem;font-family:'Inter Variable',system-ui,sans-serif;font-size:0.75rem;font-weight:600;color:#6E1019;">
                    View details
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ── CHAIRMAN'S MESSAGE ── -->
  <section style="background:#FAF6F0;padding:5rem 0;" aria-label="Chairman's message">
    <div class="container">
      <div class="chairman-grid">
        <div class="reveal">
          <span class="section-label">Leadership</span>
          <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(1.75rem,3vw,2.25rem);font-weight:700;color:#8B2A2A;margin-bottom:1rem;">Chairman's<br>Message</h2>
          <span class="divider-gold" style="margin-bottom:1.5rem;"></span>

          <img
            src={`${base}/images/chairman.png`}
            alt="Mr. Hasan Mansouri — Founder and Chairman, Hasan Mansouri Group"
            loading="lazy"
            decoding="async"
            style="
              border-radius:0.75rem;
              max-width:200px;
              width:100%;
              height:auto;
              display:block;
              object-fit:cover;
            "
          />
        </div>

        <div>
          <blockquote class="reveal reveal-delay-1" style="
            font-family:'Fraunces Variable',Georgia,serif;
            font-size:clamp(1.125rem,2vw,1.375rem);
            font-style:italic;font-weight:400;
            color:#2D1F1F;line-height:1.75;
            border-left:2px solid #B8956A;
            padding-left:1.75rem;
            margin:0 0 1.5rem;
          ">
            "I am proud to say that my company has grown from one man's dream to an organisation that is recognised as an honest, dedicated, and reliable partner in assisting our clients achieve their dreams and desires."
          </blockquote>

          <p class="reveal reveal-delay-2" style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9375rem;color:#524444;line-height:1.875;margin-bottom:1rem;">
            This philosophy applies across all our diversified businesses, from hospitality to construction and real estate development. We are committed to the pursuit of excellence and continually review and evaluate our activities to strengthen our policies with our employees and clients.
          </p>

          <div class="reveal reveal-delay-2" style="display:flex;align-items:center;gap:1rem;padding-top:1.5rem;border-top:1px solid rgba(110,16,25,0.1);">
            <div>
              <div style="font-family:'Fraunces Variable',Georgia,serif;font-size:1rem;font-weight:700;color:#2D1F1F;">Mr. Hasan Mansouri</div>
              <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.75rem;color:#B8956A;font-weight:500;letter-spacing:0.04em;">Founder &amp; Chairman, Hasan Mansouri Group</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── PARTNERS STRIP ── -->
  <section style="background:#FFFFFF;padding:3.5rem 0;border-top:1px solid rgba(110,16,25,0.08);" aria-label="Partners">
    <div class="container">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:2rem;">
        <div class="reveal">
          <span class="section-label">Associated Companies</span>
          <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:1.5rem;font-weight:700;color:#8B2A2A;margin:0;">Our Partners</h2>
        </div>
        <div class="reveal reveal-delay-1" style="display:flex;gap:1.25rem;flex-wrap:wrap;align-items:center;">
          {[
            { name: 'M & I Construction W.L.L.', sub: 'Civil & Building Contractor · Est. 1976' },
            { name: 'Spacemaker',                sub: 'Modular & Timber Frame Buildings' },
          ].map(({ name, sub }) => (
            <a href={`${base}/partners`} style="
              background:#FAF6F0;
              border:1px solid rgba(110,16,25,0.1);
              border-radius:0.75rem;
              padding:1.25rem 1.75rem;
              text-decoration:none;
              transition:box-shadow 200ms,border-color 200ms;
              display:block;
            ">
              <div style="font-family:'Fraunces Variable',Georgia,serif;font-size:1rem;font-weight:700;color:#2D1F1F;margin-bottom:0.25rem;">{name}</div>
              <div style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.75rem;color:#B8956A;font-weight:500;">{sub}</div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ── CONTACT CTA ── -->
  <section style="background:#6E1019;padding:4.5rem 0;" aria-label="Contact">
    <div class="container">
      <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:2rem;">
        <div class="reveal">
          <h2 style="font-family:'Fraunces Variable',Georgia,serif;font-size:clamp(1.5rem,3vw,2rem);font-weight:700;color:#FAF6F0;margin-bottom:0.5rem;">Get in touch with the Group</h2>
          <p style="font-family:'Inter Variable',system-ui,sans-serif;font-size:0.9375rem;color:rgba(250,246,240,0.65);">Bldg 302, Road 4306, Block 343, Mina Salman Industrial Area, Manama · (+973) 1772 8144</p>
        </div>
        <div class="reveal reveal-delay-1" style="display:flex;gap:0.875rem;flex-wrap:wrap;">
          <a href={`${base}/contact`} style="
            display:inline-flex;align-items:center;gap:0.5rem;
            background:#B8956A;color:#2D1F1F;
            padding:0.75rem 1.75rem;border-radius:3px;
            font-family:'Inter Variable',system-ui,sans-serif;
            font-size:0.875rem;font-weight:700;
            text-decoration:none;transition:background 150ms;
          ">Contact Us</a>
          <a href="tel:+97317728144" style="
            display:inline-flex;align-items:center;gap:0.5rem;
            background:rgba(250,246,240,0.1);color:#FAF6F0;
            padding:0.75rem 1.75rem;border-radius:3px;
            border:1px solid rgba(250,246,240,0.2);
            font-family:'Inter Variable',system-ui,sans-serif;
            font-size:0.875rem;font-weight:600;
            text-decoration:none;transition:background 150ms;
          ">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.12 6.12l.95-.88a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            (+973) 1772 8144
          </a>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style>
  .about-strip-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .chairman-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    align-items: start;
  }
  @media (max-width: 900px) {
    .about-strip-grid,
    .chairman-grid {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }
  }
</style>
